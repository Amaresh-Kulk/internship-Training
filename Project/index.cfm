<!DOCTYPE html>
<html>
<head>
    <title>E-commerce Online Shopping System</title>

    <style>
        body {
            margin: 0;
            font-family: Arial, Helvetica, sans-serif;
            background-color: #f4f4f4;
        }

        .container {
            width: 100%;
            text-align: center;
            margin-top: 120px;
        }

        h1 {
            color: #333;
